{
  "name": "agentwarden",
  "version": "0.0.3",
  "description": "Agent Warden CLI - A TypeScript CLI application built with Bun and Commander.js",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "type": "module",
  "bin": {
    "agentwarden": "dist/index.js"
  },
  "files": [
    "dist",
    "vendor",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:native": "bun run scripts/build_native.ts",
    "build": "bun run build:native && bun build src/index.ts --outdir dist --target bun",
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "prepublishOnly": "bun run build",
    "ci": "bun test && cargo test --manifest-path native/session-scanner/Cargo.toml && bun run build && npm pack --dry-run"
  },
  "keywords": [
    "cli",
    "typescript",
    "bun",
    "agentwarden"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.3.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "commander": "^14.0.0"
  }
}
